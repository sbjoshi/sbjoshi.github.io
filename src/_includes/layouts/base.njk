<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Homepage" }}</title>
  <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}">
</head>
<body class="page">
  {% include "resource-icons.svg" %}
  <header class="header">
    <nav class="nav">
      <ul class="nav__list">
        <li class="nav__item"><a href="{{ '/' | url }}" class="nav__link">Home</a></li>
        <li class="nav__item"><a href="{{ '/#projects' | url }}" class="nav__link">Projects</a></li>
        <li class="nav__item"><a href="{{ '/#patents' | url }}" class="nav__link">Patents</a></li>
        <li class="nav__item"><a href="{{ '/publications/' | url }}" class="nav__link">Publications</a></li>
        <li class="nav__item"><a href="{{ '/#teaching' | url }}" class="nav__link">Teaching</a></li>
        <li class="nav__item"><a href="{{ '/#students' | url }}" class="nav__link">Students</a></li>
      </ul>
    </nav>
  </header>

  <main class="main">
    {{ content | safe }}
  </main>

  <footer class="footer">
    <p class="footer__text">&copy; {{ "now" | date("yyyy") }} My Homepage</p>
  </footer>
</body>
</html>
